{
  "name": "stork-2.0",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.11.0 <23",
    "pnpm": ">=10.0.0 <11"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "supabase:link": "supabase link --project-ref imtxvrymaqbgcvsarlib",
    "types:generate": "supabase gen types typescript --linked | prettier --parser typescript > packages/types/src/database.ts",
    "types:check": "supabase gen types typescript --linked | prettier --parser typescript | diff -u packages/types/src/database.ts -",
    "schema:pull": "supabase db dump --linked --schema public --file supabase/schema.sql",
    "schema:check": "bash scripts/schema-check.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.4.2",
    "supabase": "^2.98.2",
    "turbo": "^2.3.3",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml,css,html}": [
      "prettier --write"
    ],
    "apps/web/**/*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "supabase"
    ]
  }
}
